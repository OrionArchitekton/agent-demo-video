{
  "name": "agent-demo-video",
  "version": "0.2.0",
  "description": "Generate narrated, captioned demo videos from a Markdown script and a running web app — Playwright capture + ElevenLabs TTS + ffmpeg. Supports auth-walled SaaS live capture.",
  "type": "module",
  "bin": { "demo-video": "dist/cli.js" },
  "files": ["dist", "dist-remote", "README.md", "LICENSE"],
  "keywords": [
    "demo-video", "screencast", "playwright", "ffmpeg", "narration",
    "tts", "elevenlabs", "captions", "cli"
  ],
  "license": "MIT",
  "author": "Dan Mercede",
  "repository": { "type": "git", "url": "git+https://github.com/OrionArchitekton/agent-demo-video.git" },
  "homepage": "https://github.com/OrionArchitekton/agent-demo-video#readme",
  "bugs": { "url": "https://github.com/OrionArchitekton/agent-demo-video/issues" },
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18" },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/cli.ts --format esm --target node18 --clean && pnpm build:remote-entry",
    "build:remote-entry": "tsup scripts/remote-entry.ts --format esm --target node18 --out-dir dist-remote --clean",
    "prepack": "pnpm run build",
    "demo": "tsx src/cli.ts"
  },
  "dependencies": { "playwright": "^1.48.0", "zod": "^3.23.0" },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "@types/node": "^22.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
